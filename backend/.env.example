# FastAPI Configuration
DEBUG=True
HOST=0.0.0.0
PORT=8000

# LLM Configuration
LLM_PROVIDER=gemini  # Options: "gemini" or "grok"
LLM_MODEL=gemma-4-31b-it # gemini-3-flash-preview
LLM_TEMPERATURE=0.7
GEMINI_API_KEY=your_gemini_api_key_here
GROK_API_KEY=your_groq_api_key_here

# Vector Database Configuration (Pinecone only)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west-2-aws
PINECONE_INDEX_NAME=tripverse-embeddings

# Embedding Configuration
EMBEDDING_MODEL=embedding-001
EMBEDDING_DIMENSION=768

# JIT RAG Search Configuration
SEARCH_PROVIDER=tavily  # "tavily" or "serper"
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here
SEARCH_RESULTS_COUNT=5
MAX_ARTICLE_CHARS=4000

# Application Configuration
MAX_RETRIES=5
REQUEST_TIMEOUT=120
